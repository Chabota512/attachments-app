# API server runtime configuration
# Required to run the server locally or in production.

PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Optional AI and search integration keys.
# If using a hosted Gemini AI integration, set these in your deployment environment.
AI_INTEGRATIONS_GEMINI_BASE_URL=https://api.gemini.ai
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key
EVENTBRITE_API_KEY=your-eventbrite-api-key
SERPER_API_KEY=your-serper-api-key
TAVILY_API_KEY=your-tavily-api-key
MEETUP_API_KEY=your-meetup-api-key
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_CSE_ID=your-google-cse-id
