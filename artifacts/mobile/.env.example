# Mobile app runtime configuration
# Set API_BASE_URL to your backend API host.
# If you are using the same domain for frontend and backend, you can set EXPO_PUBLIC_DOMAIN instead.

API_BASE_URL=https://your-api-host.com
EXPO_PUBLIC_DOMAIN=your-frontend-domain.com
EXPO_PUBLIC_REPL_ID=your-expo-public-repl-id
